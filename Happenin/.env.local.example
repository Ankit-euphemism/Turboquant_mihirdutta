# ────────────────────────────────────────────────────────
# Frontend Environment Variables (.env.local)
# ────────────────────────────────────────────────────────
# Note: Keep this file in .gitignore - NEVER commit secrets!
# ────────────────────────────────────────────────────────

# ──────────────────────────────────────────────
# Supabase Configuration
# ──────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_PtFOs6W9hyJsyoG9uvL1bQ_5HM6iORH
# ──────────────────────────────────────────────
# Razorpay Configuration
# ──────────────────────────────────────────────
# Get these from: Razorpay Dashboard → Settings → API Keys
# 
# ⚠️ IMPORTANT:
# - VITE_RAZORPAY_KEY_ID is PUBLIC (safe to expose in frontend)
# - RAZORPAY_KEY_SECRET goes ONLY in Supabase edge functions
#
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id_here

# Example (Test Mode):
# VITE_RAZORPAY_KEY_ID=rzp_test_1234567890abcd


# ────────────────────────────────────────────────────────
# Backend Environment Variables (Supabase Edge Functions)
# ────────────────────────────────────────────────────────
# Add these in: Supabase Dashboard → Settings → Functions
# (DO NOT add these to .env.local - add in Supabase dashboard)
#
# RAZORPAY_KEY_ID=rzp_test_your_key_id
# RAZORPAY_KEY_SECRET=your_secret_key_from_razorpay
# JWT_SECRET=base64_encoded_secret_from_openssl_rand
#
# Example of generating JWT_SECRET:
# openssl rand -base64 32
#
# Or with Node.js:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"


# ────────────────────────────────────────────────────────
# Quick Setup Commands
# ────────────────────────────────────────────────────────
# 
# 1. Generate JWT_SECRET:
#    openssl rand -base64 32
#
# 2. Get Razorpay credentials:
#    - Go to https://dashboard.razorpay.com
#    - Settings → API Keys
#    - Copy Key ID (for VITE_RAZORPAY_KEY_ID)
#    - Copy Key Secret (for RAZORPAY_KEY_SECRET in Supabase)
#
# 3. Get Supabase credentials:
#    - Supabase Dashboard → Settings → API
#    - Copy Project URL (for VITE_SUPABASE_URL)
#    - Copy Anon Key (for VITE_SUPABASE_ANON_KEY)
#
# 4. Add to .env.local (this file):
#    VITE_SUPABASE_URL=...
#    VITE_SUPABASE_ANON_KEY=...
#    VITE_RAZORPAY_KEY_ID=...
#
# 5. Add to Supabase Functions:
#    - Dashboard → Settings → Functions → Environment Variables
#    - RAZORPAY_KEY_ID
#    - RAZORPAY_KEY_SECRET
#    - JWT_SECRET
#
# 6. Deploy Edge Functions:
#    supabase functions deploy create-razorpay-order
#    supabase functions deploy verify-razorpay-payment
